{
  "$schema": "./audio-manifest.schema.json",
  "_comment": "Optional audio cue plan for the simplified Rival Hearts flow.",
  "version": 2,
  "defaults": {
    "format": ["ogg", "mp3"],
    "preload": "metadata",
    "respectsReducedMotion": false,
    "respectsAutoplayPolicy": true
  },
  "buses": {
    "ambient": { "gain": 0.4, "ducksUnder": ["sting"] },
    "ui": { "gain": 0.6 },
    "feedback": { "gain": 0.75 },
    "sting": { "gain": 0.85 }
  },
  "cues": [
    {
      "id": "ambient_court",
      "trigger": "phase:enter[confidant|suitor]",
      "bus": "ambient",
      "loop": true,
      "fadeIn": 1200,
      "fadeOut": 800,
      "style": "Solo harp with distant court murmur",
      "length": "60s loop",
      "files": ["assets/audio/ambient_court.ogg", "assets/audio/ambient_court.mp3"]
    },
    {
      "id": "seal_stamp",
      "trigger": "event:signal_placed, event:tone_chosen",
      "bus": "ui",
      "loop": false,
      "style": "Wax press with soft thud",
      "length": "350ms",
      "files": ["assets/audio/seal_stamp.ogg", "assets/audio/seal_stamp.mp3"]
    },
    {
      "id": "whisper_gossip",
      "trigger": "event:rumour_earned",
      "bus": "feedback",
      "loop": false,
      "style": "Layered close whispers, indistinct",
      "length": "1.2s",
      "files": ["assets/audio/whisper_gossip.ogg", "assets/audio/whisper_gossip.mp3"]
    },
    {
      "id": "harp_success",
      "trigger": "event:heart_earned",
      "bus": "feedback",
      "loop": false,
      "style": "Rising harp arpeggio, single bell at peak",
      "length": "2.5s",
      "files": ["assets/audio/harp_success.ogg", "assets/audio/harp_success.mp3"]
    },
    {
      "id": "tense_sting",
      "trigger": "event:reveal_hidden_facts",
      "bus": "sting",
      "loop": false,
      "style": "Low strings with struck metal",
      "length": "1.8s",
      "files": ["assets/audio/tense_sting.ogg", "assets/audio/tense_sting.mp3"]
    },
    {
      "id": "chime_phase",
      "trigger": "phase:transition",
      "bus": "ui",
      "loop": false,
      "style": "Soft tuned chime",
      "length": "500ms"
    },
    {
      "id": "defeat_sting",
      "trigger": "event:gameover[lost]",
      "bus": "sting",
      "loop": false,
      "style": "Descending strings with glass shimmer",
      "length": "3.0s"
    },
    {
      "id": "victory_sting",
      "trigger": "event:gameover[won]",
      "bus": "sting",
      "loop": false,
      "style": "Full chamber ensemble cadence",
      "length": "4.0s"
    }
  ]
}
